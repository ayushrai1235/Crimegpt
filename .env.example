# ==========================================
# CRIMEGPT - ENVIRONMENT VARIABLES TEMPLATE
# ==========================================
# Do NOT place actual passwords or API keys in this file.
# Copy this file to '.env.local' (for frontend) and '.env' (for backend functions)
# and replace the placeholder values with your actual credentials.

# ------------------------------------------
# 1. FRONTEND (Next.js)
# ------------------------------------------
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# The base URL where your local Catalyst server or production API Gateway is running
NEXT_PUBLIC_API_BASE_URL="http://localhost:3001/server"

# Your Zoho Catalyst Project ID
NEXT_PUBLIC_CATALYST_PROJECT_ID="your_catalyst_project_id_here"

# Feature toggles (Optional)
NEXT_PUBLIC_ENABLE_SPEECH="false"


# ------------------------------------------
# 2. BACKEND (Zoho Catalyst Functions)
# ------------------------------------------
# These are kept strictly on the server and are NEVER exposed to the frontend.

# -- ZOHO CATALYST --
ZOHO_CATALYST_ENVIRONMENT="Development" # Or "Production"

# -- LLM PROVIDER (Google Gemini) --
# Ensure the API key has access to the required models (e.g., gemini-3.5-flash)
LLM_PROVIDER="gemini" 
LLM_MODEL="gemini-3.5-flash"
LLM_API_KEY="AIzaSy...your_gemini_api_key_here"

# -- VECTOR DATABASE (e.g., Pinecone, Weaviate) --
VECTOR_DB_PROVIDER="pinecone"
VECTOR_DB_API_KEY="your_vector_db_api_key_here"
VECTOR_DB_ENVIRONMENT="us-east-1-aws" # Depending on your provider's region
VECTOR_DB_INDEX_NAME="crimegpt-index"

# -- GRAPH DATABASE (Neo4j AuraDB) --
NEO4J_URI="neo4j+s://your_db_id.databases.neo4j.io"
NEO4J_USERNAME="neo4j"
NEO4J_PASSWORD="your_neo4j_password_here"

# -- SECURITY & AUTHENTICATION --
# Used for encrypting sensitive fields before storing them in Catalyst Data Store
APPLICATION_ENCRYPTION_KEY="generate_a_random_32_byte_string_here"

# Used to verify incoming webhook payloads from external/legacy KSP systems
WEBHOOK_SECRET="generate_a_strong_random_secret_here"
